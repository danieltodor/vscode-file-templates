{
    "name": "file-templates-n",
    "displayName": "File/Directory Templates",
    "description": "Create reusable file and directory templates",
    "icon": "./media/icon.png",
    "version": "0.0.14",
    "preview": false,
    "publisher": "danieltodor",
    "repository": {
        "type": "git",
        "url": "https://github.com/danieltodor/vscode-file-templates"
    },
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Snippets",
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "fileTemplates.createTemplate",
                "title": "Create",
                "category": "File/Directory Templates"
            },
            {
                "command": "fileTemplates.openTemplate",
                "title": "Open",
                "category": "File/Directory Templates"
            },
            {
                "command": "fileTemplates.renameTemplate",
                "title": "Rename",
                "category": "File/Directory Templates"
            },
            {
                "command": "fileTemplates.removeTemplate",
                "title": "Remove",
                "category": "File/Directory Templates"
            },
            {
                "command": "fileTemplates.useTemplate",
                "title": "Use Template",
                "category": "File/Directory Templates"
            },
            {
                "command": "fileTemplates.useTemplates",
                "title": "Use Templates",
                "category": "File/Directory Templates"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "fileTemplates.useTemplate",
                    "when": "explorerResourceIsFolder",
                    "group": "2_workspace"
                },
                {
                    "command": "fileTemplates.useTemplates",
                    "when": "explorerResourceIsFolder",
                    "group": "2_workspace"
                }
            ]
        },
        "configuration": [
            {
                "title": "File/Directory Templates",
                "properties": {
                    "fileTemplates.template.customDirectory": {
                        "type": "string",
                        "default": "",
                        "description": "Use custom directory for the templates"
                    },
                    "fileTemplates.template.virtual": {
                        "type": "object",
                        "default": {},
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "description": "A list of virtual templates, with their real template dependencies. You can chain multiple templates together in virtual template names"
                    },
                    "fileTemplates.copy.dereferenceSymlinks": {
                        "type": "boolean",
                        "default": true,
                        "description": "In case of a symlink, copy the file itself, instead of a symlink"
                    },
                    "fileTemplates.copy.force": {
                        "type": "boolean",
                        "default": false,
                        "description": "Overwrite existing files on conflict"
                    }
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "10.0.10",
        "@types/node": "25.5.0",
        "@types/sinon": "21.0.0",
        "@types/tmp": "0.2.6",
        "@types/vscode": "1.110.0",
        "@typescript-eslint/eslint-plugin": "8.57.1",
        "@typescript-eslint/parser": "8.57.1",
        "@vscode/test-cli": "0.0.12",
        "@vscode/test-electron": "2.5.2",
        "esbuild": "0.27.4",
        "eslint": "10.1.0",
        "npm-run-all": "4.1.5",
        "sinon": "21.0.3",
        "tmp": "0.2.5",
        "typescript": "5.9.3"
    }
}
